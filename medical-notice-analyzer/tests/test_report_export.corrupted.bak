class ReportExportTests(unittest.TestCase):
    def test_quality_check_passes_for_structured_report(self) -> None:
        self.assertEqual(_quality_check_report(sample_report_ir()), [])

    def test_docx_has_clean_content_and_formal_styles(self) -> None:
        report = sample_report_ir()
        with tempfile.TemporaryDirectory() as tmp:
            path = Path(tmp) / "report.docx"
            _report_ir_to_docx(report, path, "鍖昏嵂鍏憡閲囪喘鍒嗘瀽鎶ュ憡")
            with ZipFile(path) as zf:
                document_xml = zf.read("word/document.xml").decode("utf-8")
                footer_files = [name for name in zf.namelist() if name.startswith("word/footer")]
                footer_xml = "\n".join(zf.read(name).decode("utf-8") for name in footer_files)
        self.assertIn("鍥介噰鍐犺剦鏀灦绗簩杞帴缁惎鍔?, document_xml)
        self.assertIn("澹版槑", document_xml)
        self.assertIn("w:shd", document_xml)
        self.assertIn("w:tblHeader", document_xml)
        self.assertIn("PAGE", footer_xml)
        self.assertNotIn("<think>", document_xml)
        self.assertNotIn("analysis", document_xml)

    def test_export_layer_rejects_raw_model_reply_without_final_region(self) -> None:
        with self.assertRaises(ValueError):
            _prepare_report_for_export(ExportReportRequest(markdown="鎴戝噯澶囧厛鍒嗘瀽锛岀劧鍚庡啓鎶ュ憡銆?))

    def test_final_report_fallback_does_not_export_thinking(self) -> None:
        raw = """
<think>We need to reason here.</think>
<final_report>
# 鍥介噰鍐犺剦鏀灦绗簩杞帴缁惎鍔紝婊¤冻鎶ヤ环瑕佹眰鍗冲彲涓€?
鍥藉缁勭粐鍖荤敤鑰楁潗鑱斿悎閲囪喘骞冲彴浜?026骞?鏈?3鏃ュ彂甯冮噰璐枃浠讹紝閲囪喘鍝佺涓哄啝鐘跺姩鑴夎嵂鐗╂礂鑴辨敮鏋讹紝閲囪喘鍛ㄦ湡鑷?029骞?鏈?0鏃ャ€?
## 閲囪喘闇€姹傞噺
| 鍝佺 | 棣栧勾閲囪喘闇€姹傞噺 |
| --- | --- |
| 鍐犵姸鍔ㄨ剦鑽墿娲楄劚鍚堥噾鏀灦 | 2,726,093涓?|

## 浠锋牸瑙勫垯
| 搴忓彿 | 鍝佺 | 鏈€楂樻湁鏁堢敵鎶ヤ环 | 璇环鍩哄噯 |
| --- | --- | --- | --- |
| 1 | 鍐犵姸鍔ㄨ剦鑽墿娲楄劚鍚堥噾鏀灦 | 949鍏?涓?| 848鍏?涓?|

## 姊害甯﹂噺姣斾緥
| 鍝佺 | 浠锋牸鍖洪棿 | 鍩虹甯﹂噺姣斾緥 |
| --- | --- | --- |
| 鍐犵姸鍔ㄨ剦鑽墿娲楄劚鍚堥噾鏀灦 | 涓€変环鏍尖墹848 | 90% |

## 鍏抽敭鏃堕棿鑺傜偣
| 浜嬮」 | 鏃堕棿 | 瑕佹眰 |
| --- | --- | --- |
| 鍖讳繚缂栫爜鐢宠 | 2026骞?鏈?8鏃?| 瀹屾垚浜у搧淇℃伅缁存姢 |
</final_report>
"""
        report = _parse_model_output_to_report_ir(raw)
        text = "\n".join(report.lead_paragraphs + [p for s in report.sections for p in s.paragraphs])
        self.assertNotIn("We need", text)
        self.assertNotIn("<think>", text)
        self.assertNotIn("绗竴閮ㄥ垎", report.title)

class XjbtylbzExtractionTests(unittest.TestCase):
    def test_extracts_hash_route_news_id(self) -> None:
        self.assertEqual(
            _extract_xjbtylbz_news_id("https://gwt.xjbtylbz.cn/hallEnter/#/news/320"),
            "320",
        )

    def test_latest_info_item_becomes_parseable_detail_html(self) -> None:
        item = {
            "infoId": "320",
            "title": "\u5173\u4e8e\u5f00\u5c55\u5175\u56e2\u62db\u91c7\u5b50\u7cfb\u7edf\u533b\u7528\u8017\u6750\u9633\u5149\u6302\u7f51\u4ef7\u683c\u8054\u52a8\u5de5\u4f5c\u7684\u901a\u77e5",
            "content": (
                "<p>\u4e00\u3001\u4ef7\u683c\u8054\u52a8\u65f6\u95f4</p>"
                "<p>2026\u5e744\u67088\u65e5\u20142026\u5e744\u670817\u65e5</p>"
                "<p>\u9644\u4ef6\uff1a<a href=\"https://gwt.xjbtylbz.cn:20002/ADMIN_test.xlsx\">"
                "1.\u4ef7\u683c\u9ad8\u4e8e\u81ea\u6cbb\u533a\u5e73\u53f0\u4ea7\u54c1\u6c47\u603b\u8868</a></p>"
            ),
            "crterTime": "2026-04-07 18:41:12",
        }

        detail = _xjbtylbz_latest_info_to_detail(item)

        self.assertEqual(detail["title"], item["title"])
        self.assertIn("2026-04-07 18:41:12", detail["release_time"])
        self.assertIn(item["title"], detail["html"])
        self.assertIn("ADMIN_test.xlsx", detail["html"])

    def test_xjbtylbz_attachment_download_uses_page_referer(self) -> None:
        headers = _attachment_request_headers("https://gwt.xjbtylbz.cn:20002/ADMIN_test.xlsx")

        self.assertEqual(headers["Referer"], "https://gwt.xjbtylbz.cn/hallEnter/")
        self.assertEqual(headers["Origin"], "https://gwt.xjbtylbz.cn")


class ElianQxExtractionTests(unittest.TestCase):
    def test_extracts_company_article_id_from_project_information_url(self) -> None:
        self.assertEqual(
            _extract_elian_qx_article_id(
                "https://qx.eliancloud.cn/zly/gwzr/zcfw/projectInformationArticleContent?articleid=b0e6daf6-10a8-4512-a8a7-a4faa2c9b0d5"
            ),
            "b0e6daf6-10a8-4512-a8a7-a4faa2c9b0d5",
        )

    def test_company_article_json_is_converted_to_detail_html(self) -> None:
        detail = _elian_qx_article_to_detail(
            {
                "title": "鐪佸尰淇濆眬鍏充簬寮€灞曞尰鐢ㄨ€楁潗闃冲厜鎸傜綉閲囪喘鐢虫姤宸ヤ綔鐨勯€氱煡",
                "audittime": "2026-06-01",
                "source": "璐靛窞鐪佸尰鐤椾繚闅滃眬",
                "content": "<p>浼佷笟搴旀寜瑕佹眰杩涜闃冲厜鎸傜綉閲囪喘鐢虫姤銆?/p>",
                "attachments": [
                    {"filename": "鐢虫姤鏉愭枡.xlsx", "url": "https://qx.eliancloud.cn/prod-api/common/download?fileName=test.xlsx"}
                ],
            }
        )

        self.assertEqual(detail["title"], "鐪佸尰淇濆眬鍏充簬寮€灞曞尰鐢ㄨ€楁潗闃冲厜鎸傜綉閲囪喘鐢虫姤宸ヤ綔鐨勯€氱煡")
        self.assertIn("2026-06-01", detail["html"])
        self.assertIn("浼佷笟搴旀寜瑕佹眰杩涜闃冲厜鎸傜綉閲囪喘鐢虫姤", detail["html"])
        self.assertIn("鐢虫姤鏉愭枡.xlsx", detail["html"])

    def test_company_auth_failure_is_recognized(self) -> None:
        self.assertTrue(_is_elian_qx_auth_failed({"code": 401, "msg": "璁よ瘉澶辫触锛屾棤娉曡闂郴缁熻祫婧?}))
        self.assertTrue(_is_elian_qx_auth_failed({"msg": "鐧诲綍鐘舵€佸凡杩囨湡"}))

    def test_analyze_returns_crawl_insufficient_when_page_fetch_fails(self) -> None:
        async def failing_fetch(_: str) -> dict[str, str]:
            request = httpx.Request("GET", "https://example.com/notice")
            response = httpx.Response(412, request=request)
            raise httpx.HTTPStatusError("Precondition Failed", request=request, response=response)

        async def no_site_detail(_: str, __: list[str]) -> dict[str, str] | None:
            return None

        async def no_firecrawl(*_: object) -> str:
            return ""

        original_fetch = main_module._fetch_page
        original_site_detail = main_module._try_known_site_detail
        original_firecrawl = main_module._try_firecrawl
        try:
            main_module._fetch_page = failing_fetch
            main_module._try_known_site_detail = no_site_detail
            main_module._try_firecrawl = no_firecrawl

            response = asyncio.run(
                main_module.analyze(
                    AnalyzeRequest(url="https://example.com/notice", max_attachments=0, max_combined_chars=20_000)
                )
            )
        finally:
            main_module._fetch_page = original_fetch
            main_module._try_known_site_detail = original_site_detail
            main_module._try_firecrawl = original_firecrawl

        self.assertIn("crawl_insufficient", "\n".join(response.warnings))
        self.assertIn("鎶撳彇鐘舵€? crawl_insufficient", response.evidence_for_llm)
        self.assertIn("鍏憡缃戦〉鎶撳彇澶辫触", response.evidence_for_llm)

    def test_zero_attachment_limit_returns_no_links(self) -> None:
        html = '<a href="https://example.com/file.xlsx">\u9644\u4ef61</a>'

        self.assertEqual(_discover_attachment_links(html, "https://example.com/page", 0), [])


class HenanExtractionTests(unittest.TestCase):
    def test_parse_html_prefers_henan_message_content_over_navigation(self) -> None:
        html = """
<html><head><title>\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5</title></head>
<body><div class="menu">\u9996\u9875 \u901a\u77e5 \u516c\u793a \u653f\u7b56\u6587\u4ef6 \u8054\u7cfb\u6211\u4eec</div></body></html>
<div class="els-box els-messageinfo-box">
  <div class="els-contentTitle">\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5</div>
  <div class="content-source"><span>\u53d1\u5e03\u65f6\u95f4\uff1a2026-05-27</span></div>
  <div class="els-contentCon">
    <p>\u81ea2026\u5e746\u67081\u65e5\u8d77\uff0c\u76f8\u5173\u4f01\u4e1a\u987b\u901a\u8fc7\u201c\u533b\u7528\u8017\u6750\u6302\u7f51\u5168\u56fd\u8054\u5ba1\u901a\u529e\u201d\u5411\u6211\u7701\u63d0\u4ea4\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u3002</p>
    <p>\u539f\u8017\u6750\u9633\u5149\u6302\u7f51\u6a21\u5757\u7533\u62a5\u529f\u80fd\u5373\u65e5\u8d77\u5173\u95ed\uff0c\u4fdd\u7559\u67e5\u8be2\u529f\u80fd\u3002</p>
  </div>
</div>
"""

        parsed = _parse_html(html, "https://ypnew.hnsggzyjy.henan.gov.cn/cms/detail.html?infoId=1330")

        self.assertEqual(parsed["title"], "\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5")
        self.assertIn("\u81ea2026\u5e746\u67081\u65e5\u8d77", parsed["text"])
        self.assertIn("\u533b\u7528\u8017\u6750\u6302\u7f51\u5168\u56fd\u8054\u5ba1\u901a\u529e", parsed["text"])
        self.assertNotEqual(parsed["text"], "\u9996\u9875\n\n\u901a\u77e5\n\n\u516c\u793a\n\n\u653f\u7b56\u6587\u4ef6\n\n\u8054\u7cfb\u6211\u4eec")

    def test_extracts_publish_date_without_template_edit_dates(self) -> None:
        html = """
<!-- @Date: 2022-09-23 12:24:46 @LastEditTime: 2022-10-17 10:16:45 -->
<span>\u53d1\u5e03\u65f6\u95f4\uff1a
    2026-05-27
</span>
"""

        self.assertEqual(_extract_publish_metadata_dates(html), ["2026-05-27"])


class ExportHardeningTests(unittest.TestCase):
    def test_report_ir_new_fields_survive_normalization_and_filename(self) -> None:
        report = _normalize_report_ir(
            ReportIR(
                title="\u0036\u6708\u0031\u65e5\u8d77\uff0c\u6cb3\u5357\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u8f6c\u5165\u5168\u56fd\u8054\u5ba1\u901a\u529e",
                suggested_filename="\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011",
                notice_type="\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u7c7b",
                publish_date="2026-05-27",
                source_agency="\u6cb3\u5357\u7701\u516c\u5171\u8d44\u6e90\u4ea4\u6613\u4e2d\u5fc3",
                document_name="\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5",
                lead_paragraphs=["\u81ea2026\u5e746\u67081\u65e5\u8d77\uff0c\u76f8\u5173\u4f01\u4e1a\u987b\u901a\u8fc7\u5168\u56fd\u8054\u5ba1\u901a\u529e\u63d0\u4ea4\u7533\u62a5\u3002"],
            ),
            fallback_title="",
        )

        self.assertEqual(report.notice_type, "\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u7c7b")
        self.assertEqual(report.suggested_filename, "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011")
        self.assertEqual(
            _build_report_filename(report),
            "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011.docx",
        )

    def test_sanitize_filename_removes_illegal_markdown_dify_and_watermark(self) -> None:
        raw = '# {{#node.title#}} \u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750/\u6302\u7f51:\u6d41\u7a0b*\u8c03\u6574?\u2014\u6c34\u5370\u9879\u76ee\u5206\u6790\u301020260527\u3011 ```'

        self.assertEqual(
            _sanitize_filename(raw),
            "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011.docx",
        )

    def test_unique_report_filename_appends_counter(self) -> None:
        with tempfile.TemporaryDirectory() as tmp:
            directory = Path(tmp)
            existing = "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011.docx"
            (directory / existing).write_text("x", encoding="utf-8")

            self.assertEqual(
                _unique_report_filename(existing, directory),
                "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011(1).docx",
            )

    def test_report_ir_parses_json_code_fence_and_cleans_fields(self) -> None:
        raw = """
<think>\u4e0d\u8981\u8fdb\u5165 Word</think>
<report_ir>
```json
{
  "title": "# 6\u67081\u65e5\u8d77\uff0c\u6cb3\u5357\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u8f6c\u5165\u5168\u56fd\u8054\u5ba1\u901a\u529e",
  "suggested_filename": "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011",
  "notice_type": "\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u7c7b",
  "publish_date": "2026-05-27",
  "source_agency": "{{#fetch_node.body#}}\u6cb3\u5357\u7701\u516c\u5171\u8d44\u6e90\u4ea4\u6613\u4e2d\u5fc3",
  "document_name": "\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5",
  "lead_paragraphs": ["<br>\u81ea2026\u5e746\u67081\u65e5\u8d77\uff0c\u76f8\u5173\u4f01\u4e1a\u987b\u901a\u8fc7\u201c\u533b\u7528\u8017\u6750\u6302\u7f51\u5168\u56fd\u8054\u5ba1\u901a\u529e\u201d\u63d0\u4ea4\u7533\u62a5\u3002"],
  "sections": [],
  "enterprise_tips": [],
  "disclaimer": ""
}
```
</report_ir>
"""

        report = _prepare_report_for_export(ExportReportRequest(markdown=raw))
        text = "\n".join([report.title, report.source_agency, *report.lead_paragraphs])

        self.assertEqual(report.notice_type, "\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u7c7b")
        self.assertNotIn("{{", text)
        self.assertNotIn("<br>", text)
        self.assertNotIn("<think>", text)
        self.assertFalse(report.title.startswith("#"))

    def test_table_rows_are_normalized_without_crashing_or_losing_notes(self) -> None:
        report = _normalize_report_ir(
            ReportIR(
                title="\u6d4b\u8bd5\u62a5\u544a\u6807\u9898",
                sections=[
                    ReportSection(
                        heading="\u89c4\u5219\u8868",
                        tables=[
                            ReportTable(
                                title="\u88681 \u6d41\u7a0b\u53d8\u5316\u8868",
                                headers=["\u4e8b\u9879", "\u8981\u6c42"],
                                rows=[
                                    ["\u7533\u62a5\u5165\u53e3"],
                                    ["\u5e73\u53f0\u8def\u5f84", "\u6cb3\u5357\u5e73\u53f0", "\u591a\u4f59\u5185\u5bb9"],
                                ],
                                notes=["\u8868\u4e2d\u4e3a\u539f\u6587\u6d41\u7a0b\u4fe1\u606f\u3002"],
                            )
                        ],
                    )
                ],
            ),
            fallback_title="",
        )

        table = report.sections[0].tables[0]
        self.assertEqual(table.rows[0], ["\u7533\u62a5\u5165\u53e3", ""])
        self.assertEqual(table.rows[1], ["\u5e73\u53f0\u8def\u5f84", "\u6cb3\u5357\u5e73\u53f0\uff1b\u591a\u4f59\u5185\u5bb9"])
        self.assertEqual(table.notes, ["\u8868\u4e2d\u4e3a\u539f\u6587\u6d41\u7a0b\u4fe1\u606f\u3002"])

    def test_docx_export_writes_yilian_watermark_and_omits_json(self) -> None:
        report = _normalize_report_ir(
            ReportIR(
                title="\u6cb3\u5357\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574",
                suggested_filename="\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011",
                notice_type="\u6302\u7f51\u6d41\u7a0b\u8c03\u6574\u7c7b",
                publish_date="2026-05-27",
                source_agency="\u6cb3\u5357\u7701\u516c\u5171\u8d44\u6e90\u4ea4\u6613\u4e2d\u5fc3",
                document_name="\u5173\u4e8e\u8c03\u6574\u533b\u7528\u8017\u6750\u7533\u62a5\u6302\u7f51\u64cd\u4f5c\u6d41\u7a0b\u7684\u901a\u77e5",
                lead_paragraphs=["\u8fd9\u662f\u6b63\u5f0f\u62a5\u544a\u6b63\u6587\u3002"],
            ),
            fallback_title="",
        )
        with tempfile.TemporaryDirectory() as tmp:
            path = Path(tmp) / "report.docx"
            _report_ir_to_docx(report, path, "")
            with ZipFile(path) as zf:
                xml = "\n".join(zf.read(name).decode("utf-8") for name in zf.namelist() if name.startswith("word/") and name.endswith(".xml"))

        self.assertIn("PowerPlusWaterMarkObject", xml)
        self.assertIn('string="鏄撹仈鍣ㄦ"', xml)
        self.assertNotIn("<report_ir>", xml)
        self.assertNotIn("suggested_filename", xml)
        self.assertNotIn("{{#", xml)

    def test_disclaimer_uses_requested_chinese_fonts_and_sizes(self) -> None:
        report = _normalize_report_ir(sample_report_ir(), fallback_title="")
        with tempfile.TemporaryDirectory() as tmp:
            path = Path(tmp) / "report.docx"
            _report_ir_to_docx(report, path, "")
            paragraphs = _docx_paragraphs(path)

        disclaimer_heading = next(p for p in paragraphs if _paragraph_text(p) == "澹? 鏄?)
        disclaimer_body = next(p for p in paragraphs if DEFAULT_DISCLAIMER in _paragraph_text(p))

        heading_props = _first_run_props(disclaimer_heading)
        body_props = _first_run_props(disclaimer_body)
        self.assertIsNotNone(heading_props)
        self.assertIsNotNone(body_props)

        heading_fonts = heading_props.find("w:rFonts", DOCX_NS)
        heading_size = heading_props.find("w:sz", DOCX_NS)
        body_fonts = body_props.find("w:rFonts", DOCX_NS)
        body_size = body_props.find("w:sz", DOCX_NS)

        self.assertEqual("妤蜂綋", heading_fonts.attrib[f"{{{DOCX_NS['w']}}}eastAsia"])
        self.assertEqual("44", heading_size.attrib[f"{{{DOCX_NS['w']}}}val"])
        self.assertEqual("瀹嬩綋", body_fonts.attrib[f"{{{DOCX_NS['w']}}}eastAsia"])
        self.assertEqual("32", body_size.attrib[f"{{{DOCX_NS['w']}}}val"])

    def test_report_ir_renders_to_markdown_for_dify_display(self) -> None:
        report = _normalize_report_ir(sample_report_ir(), fallback_title="")

        markdown = _report_ir_to_markdown(report)

        self.assertIn("# 鍥介噰鍐犺剦鏀灦绗簩杞帴缁惎鍔紝婊¤冻鎶ヤ环瑕佹眰鍗冲彲涓€?, markdown)
        self.assertIn("## 閲囪喘闇€姹傞噺", markdown)
        self.assertIn("### 琛? 閲囪喘闇€姹傞噺鎬昏〃", markdown)
        self.assertIn("| 鍝佺 | 棣栧勾閲囪喘闇€姹傞噺 | 澶囨敞 |", markdown)
        self.assertIn("- 浜у搧鐢虫姤浠锋牸涓嶈秴杩囨渶楂樻湁鏁堢敵鎶ヤ环鐨勶紝鍙幏寰椾腑閫夎祫鏍笺€?, markdown)
        self.assertIn("## 浼佷笟鍏虫敞鐐?, markdown)
        self.assertIn("- 浼佷笟闇€鏍稿娉ㄥ唽璇併€佸巻鍙蹭环鏍煎拰渚涘簲鑳藉姏锛屾祴绠椾笉鍚屾姤浠蜂笅鐨勫甫閲忓奖鍝嶃€?, markdown)
        self.assertNotIn(DEFAULT_DISCLAIMER, markdown)

