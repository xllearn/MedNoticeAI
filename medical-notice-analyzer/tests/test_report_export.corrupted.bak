    def test_checked_export_uses_public_base_url_for_download_link(self) -> None:
        old_base_url = os.environ.get("PUBLIC_BASE_URL")
        os.environ["PUBLIC_BASE_URL"] = "http://192.168.34.88:8099/"
        try:
            response = export_report_checked(
                CheckedExportReportRequest(
                    report_ir=sample_report_ir(),
                    qa_output='{"status":"pass","issues":[],"unsupported_claims":[],"history_leakage":[],"missing_rules":[],"language_issues":[],"fix_instructions":[],"summary":"閫氳繃"}',
                )
            )
        finally:
            if old_base_url is None:
                os.environ.pop("PUBLIC_BASE_URL", None)
            else:
                os.environ["PUBLIC_BASE_URL"] = old_base_url

        self.assertTrue(response.success)
        self.assertTrue(response.download_url.startswith("http://192.168.34.88:8099/download/"))

    def test_docx_uses_fixed_disclaimer_and_hides_notice_type_metadata(self) -> None:
        report = _normalize_report_ir(
            ReportIR(
                title="骞夸笢楹婚唹绠¤矾绛変笁绫昏€楁潗甯﹂噺鑱斿姩閲囪喘椤圭洰鍒嗘瀽",
                suggested_filename="銆愬箍涓溿€戦夯閱夌璺瓑涓夌被鑰楁潗甯﹂噺鑱斿姩閲囪喘椤圭洰鍒嗘瀽銆?0260531銆?,
                notice_type="寰佹眰鎰忚绋跨被",
                publish_date="2026-05-31",
                source_agency="娣卞湷鍏叡璧勬簮浜ゆ槗涓績",
                document_name="骞夸笢鐪侀夯閱夌璺瓑涓夌被鍖荤敤鑰楁潗甯﹂噺鑱斿姩閲囪喘鏂囦欢",
                lead_paragraphs=["娣卞湷鍏叡璧勬簮浜ゆ槗涓績鍙戝竷閲囪喘鏂囦欢锛屾秹鍙婇夯閱夌璺瓑涓夌被鑰楁潗銆?],
                disclaimer="鏈姤鍛婂熀浜庢煇鏌愬叕鍛婃挵鍐欙紝浠呬緵琛屼笟鍙傝€冦€?,
            ),
            fallback_title="",
        )
        with tempfile.TemporaryDirectory() as tmp:
            path = Path(tmp) / "report.docx"
            _report_ir_to_docx(report, path, "")
            text = _docx_body_text(path)

        self.assertIn("澹? 鏄?, text)
        self.assertIn("鏈枃鍩轰簬浜掕仈缃戝叕寮€璧勬枡杩涜鏁寸悊锛岀洰鐨勫湪浜庝紶閫掑垎浜俊鎭紝浠呬緵璇昏€呭弬鑰冧箣鐢ㄣ€?, text)
        self.assertNotIn("鏈姤鍛婂熀浜庢煇鏌愬叕鍛婃挵鍐?, text)
        self.assertNotIn("鍏憡绫诲瀷", text)
        self.assertNotIn("寰佹眰鎰忚绋跨被", text)

    def test_clean_inline_text_replaces_modelized_language(self) -> None:
        text = _clean_inline_text(
            "鍏ㄥ浗鏈€浣庝环鍒氭€ф姢鍩庢渤锛屼笉缁欎环鏍艰櫄楂樼暀浠讳綍姝昏锛涗腑閫夊嵆瑙﹂浄锛屼紒涓氶潰涓撮噸澶у啿鍑汇€?
        )

        self.assertIn("浠锋牸鑱斿姩瑕佹眰", text)
        self.assertIn("浼佷笟闇€鍏虫敞鍚庣画浠锋牸璋冩暣涔夊姟", text)
        self.assertNotIn("鍒氭€ф姢鍩庢渤", text)
        self.assertNotIn("涓嶇粰浠锋牸铏氶珮鐣欎换浣曟瑙?, text)
        self.assertNotIn("涓€夊嵆瑙﹂浄", text)
        self.assertNotIn("閲嶅ぇ鍐插嚮", text)

    def test_rule_completeness_hints_detects_source_rule_sections(self) -> None:
        hints = _rule_completeness_hints(
            "閲囪喘鍝佺鑼冨洿鍖呮嫭楹婚唹绠¤矾銆備紒涓氭姤浠疯姹傚涓嬨€傛嫙涓€変骇鍝佺‘瀹氳鍒欏涓嬨€?
            "閲囪喘鎵ц璇存槑銆佷环鏍艰仈鍔ㄣ€侀潪涓€変骇鍝佺鐞嗗拰鍚嶈瘝瑙ｉ噴鍧囧湪鏂囦欢涓垪鏄庛€?
        )

        self.assertIn("瑙勫垯瀹屾暣鎬т繚鐣欐彁绀?, hints)
        self.assertIn("閲囪喘鍝佺鑼冨洿", hints)
        self.assertIn("浼佷笟鎶ヤ环瑕佹眰", hints)
        self.assertIn("鎷熶腑閫変骇鍝佺‘瀹?, hints)
        self.assertIn("闈炰腑閫変骇鍝佺鐞?, hints)
        self.assertIn("鍚嶈瘝瑙ｉ噴", hints)

    def test_download_report_sets_utf8_content_disposition(self) -> None:
        filename = "\u3010\u6cb3\u5357\u3011\u533b\u7528\u8017\u6750\u6302\u7f51\u7533\u62a5\u6d41\u7a0b\u8c03\u6574\u2014\u9879\u76ee\u5206\u6790\u301020260527\u3011.docx"
        report_path = Path("/tmp/medical-notice-reports") / filename
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_bytes(b"docx")

        response = download_report(filename)

        self.assertEqual(
            response.media_type,
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        )
        self.assertIn("filename*=UTF-8''", response.headers["content-disposition"])
        self.assertIn("%E3%80%90%E6%B2%B3%E5%8D%97%E3%80%91", response.headers["content-disposition"])


class ReportQAEnhancementTests(unittest.TestCase):
    def test_parse_qa_output_accepts_json_code_fence_and_blocks_history_leakage(self) -> None:
        raw = """
<think>涓嶈杩涘叆缁撴灉</think>
```json
{
  "status": "needs_fix",
  "issues": [],
  "unsupported_claims": [],
  "history_leakage": [
    {
      "severity": "major",
      "category": "history_fact_leakage",
      "report_text": "閲囪喘鍛ㄦ湡涓?骞?,
      "source_quote": "",
      "fix_instruction": "鍒犻櫎鍘嗗彶绋垮懆鏈熻〃杩?
    }
  ],
  "missing_rules": ["闈炰腑閫変骇鍝佺鐞?],
  "language_issues": [],
  "fix_instructions": ["涓嶈涓哄巻鍙插垎鏋愭柊澧炴爣棰?],
  "summary": "瀛樺湪鍘嗗彶浜嬪疄娉勬紡锛岄渶淇銆?
}
```
"""

        qa = _parse_qa_output(raw)

        self.assertEqual(qa.status, "needs_fix")
        self.assertEqual(qa.history_leakage[0].category, "history_fact_leakage")
        self.assertTrue(_qa_blocks_export(qa))
        self.assertIn("瀛樺湪鍘嗗彶浜嬪疄娉勬紡", _format_qa_summary(qa))

    def test_parse_qa_output_invalid_json_raises_parse_error(self) -> None:
        with self.assertRaises(ValueError):
            _parse_qa_output("<think>debug</think>{not json")

    def test_checked_export_reports_qa_defects_but_still_exports_word(self) -> None:
        qa_output = """
{
  "status": "needs_fix",
  "issues": [],
  "unsupported_claims": [],
  "history_leakage": [
    {"severity":"major","category":"history_fact_leakage","report_text":"閲囪喘鍛ㄦ湡涓?骞?,"fix_instruction":"鍒犻櫎鍘嗗彶鍛ㄦ湡"}
  ],
  "missing_rules": [],
  "language_issues": [],
