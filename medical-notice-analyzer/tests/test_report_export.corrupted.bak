    def test_history_leakage_detects_new_history_heading_and_fact_transfer(self) -> None:
        report_text = (
            "## 鍘嗗彶瀵圭収\n"
            "缁撳悎鏃㈠線鍚岀被椤圭洰缁忛獙锛屾湰娆″叕鍛婇噰璐懆鏈熶负2骞达紝鏈€楂樻湁鏁堢敵鎶ヤ环涓?28鍏冦€?
        )
        history_text = "鍘嗗彶鍒嗘瀽绋挎樉绀猴細閲囪喘鍛ㄦ湡涓?骞达紝鏈€楂樻湁鏁堢敵鎶ヤ环涓?28鍏冦€?
        evidence_text = "鏈鍏憡浠呮姭闇茬敵鎶ュ叆鍙ｈ皟鏁达紝鏈姭闇查噰璐懆鏈熷拰鏈€楂樻湁鏁堢敵鎶ヤ环銆?

        issues = _detect_history_leakage(report_text, history_text, evidence_text)

        self.assertGreaterEqual(len(issues), 2)
        self.assertTrue(any(issue.category == "history_heading" for issue in issues))
        self.assertTrue(any("128鍏? in issue.report_text for issue in issues))

    def test_prompt_files_contain_history_revision_and_qa_constraints(self) -> None:
        prompt_dir = Path(__file__).resolve().parents[1] / "prompts"
        history_prompt = (prompt_dir / "report_history_prompt.md").read_text(encoding="utf-8")
        revision_prompt = (prompt_dir / "report_revision_prompt.md").read_text(encoding="utf-8")
        qa_prompt = (prompt_dir / "report_qa_prompt.md").read_text(encoding="utf-8")
        qa_fix_prompt = (prompt_dir / "report_qa_fix_prompt.md").read_text(encoding="utf-8")
        system_prompt = (prompt_dir / "report_system_prompt.md").read_text(encoding="utf-8")
        user_prompt = (prompt_dir / "report_user_prompt.md").read_text(encoding="utf-8")

        self.assertIn("涓嶅緱浣滀负鏈鍏憡浜嬪疄鏉ユ簮", history_prompt)
        self.assertIn("寮哄埗涓嶆柊澧炴爣棰?, history_prompt)
        self.assertIn("涓嶅厑璁歌劚绂诲師鏂囨柊澧炰簨瀹?, revision_prompt)
        self.assertIn("鐢ㄦ埛鍙嶉淇鍙兘鍩轰簬 source_evidence", revision_prompt)
        self.assertIn("涓嶅緱鏂板缃戦〉鎴栭檮浠舵病鏈夌殑浜嬪疄", revision_prompt)
        self.assertIn("闄ら潪鐢ㄦ埛鏄庣‘瑕佹眰鍒犻櫎", revision_prompt)
        self.assertIn("鍙緭鍑?<report_ir>", revision_prompt)
        self.assertIn("history_leakage", qa_prompt)
        self.assertIn("鍙寜 fix_instructions 淇", qa_fix_prompt)
        self.assertIn("鍘嗗彶鍒嗘瀽绋垮彧鑳界敤浜?, system_prompt)
        self.assertIn("涓嶈兘鎶婂巻鍙?Word 涓殑瑙勫垯銆佷环鏍笺€佸懆鏈?, system_prompt)
        self.assertIn("浜哄伐琛屼笟鍒嗘瀽绋跨粨鏋勫熀鍑?, system_prompt)
        self.assertIn("璇佹嵁涓板瘜鏃朵笉瑕佸啓鎴愮煭鎽樿", system_prompt)
        self.assertIn("鍙傝€冩姤鍛婂彧浣滀负缁撴瀯鍜岄鏍煎弬鑰?, system_prompt)
        self.assertIn("鍙緭鍑?<report_ir>", system_prompt)
        self.assertIn("鍙緭鍑?<report_ir>", user_prompt)
        self.assertIn("1800", user_prompt)
        self.assertIn("1800", qa_prompt)
        self.assertIn("閫愯〃妫€鏌?, qa_prompt)
        self.assertIn("琛ㄦ牸鏍囬銆佽〃澶淬€佸叧閿暟鍊笺€佸崟浣?, qa_prompt)
        self.assertIn("鍙緭鍑?<report_ir>", qa_fix_prompt)
        self.assertIn("涓嶅緱鍘嬬缉宸茬粡鍚堟牸鐨勯暱鎶ュ憡", qa_fix_prompt)
        self.assertIn("鏈哄埗绾с€佹柟鍚戞€х殑涓茶仈淇℃伅", history_prompt)
        self.assertIn("涓嶅啓鍏蜂綋浠锋牸銆佺櫨鍒嗘瘮銆侀噰璐懆鏈?, history_prompt)
        self.assertNotIn("</final_report>", system_prompt)
        self.assertNotIn("</final_report>", user_prompt)
        self.assertNotIn("</final_report>", qa_fix_prompt)
        self.assertNotIn("<final_report>", revision_prompt)
        self.assertNotIn("</final_report>", revision_prompt)
        self.assertNotIn("蹇呴』鍚屾椂杈撳嚭涓や釜鍖哄煙", system_prompt)
        self.assertNotIn("蹇呴』杈撳嚭 <report_ir> 缁撴瀯鍖?JSON 鍜?<final_report>", user_prompt)

    def test_workflow_uses_render_node_and_reduced_evidence_budget(self) -> None:
        root = Path(__file__).resolve().parents[1]
        workflow = (root / "dify-workflow-medical-notice-report.yml").read_text(encoding="utf-8")
        enhancer = (root / "scripts" / "enhance_dify_workflow_graph.py").read_text(encoding="utf-8")

        self.assertIn('"max_combined_chars":80000', workflow)
        self.assertIn("/report/render", workflow)
        self.assertIn("/report/render", enhancer)
        self.assertIn("render_report_node", workflow)
        self.assertIn("render_report_node", enhancer)
        self.assertIn("report_markdown", enhancer)
        self.assertNotIn("{{#report_node.text#}}\\n\\nfinal_report", enhancer)

    def test_enhanced_workflow_does_not_mix_disabled_thinking_and_reasoning_effort(self) -> None:
        root = Path(__file__).resolve().parents[1]
        graph_path = root / "dify-db-backups" / "workflow-8216a411-graph-enhanced.json"
        graph = json.loads(graph_path.read_text(encoding="utf-8"))

        bad_nodes = []
        for node in graph["nodes"]:
            if node.get("data", {}).get("type") != "llm":
                continue
            params = node["data"]["model"].get("completion_params", {})
            if params.get("thinking") is False and "reasoning_effort" in params:
                bad_nodes.append(node["id"])

        self.assertEqual([], bad_nodes)


class AttachmentCollectionTests(unittest.IsolatedAsyncioTestCase):
    async def test_collects_attachments_concurrently_and_keeps_failures_as_warnings(self) -> None:
        links = [
            {"url": "https://example.com/1.xlsx", "text": "闄勪欢1"},
            {"url": "https://example.com/2.xlsx", "text": "闄勪欢2"},
            {"url": "https://example.com/3.xlsx", "text": "闄勪欢3"},
        ]
        original_download = main_module._download_attachment
        original_parse = main_module._parse_attachment

        async def fake_download(url: str) -> DownloadedFile:
            import asyncio

            await asyncio.sleep(0.15)
            if url.endswith("2.xlsx"):
                raise RuntimeError("403 Forbidden")
            return DownloadedFile(
                url=url,
                filename=Path(url).name,
                content_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                content=b"xlsx",
            )

        def fake_parse(downloaded: DownloadedFile) -> dict[str, object]:
            return {"text": f"parsed {downloaded.filename}", "tables": [], "warnings": []}

        main_module._download_attachment = fake_download
        main_module._parse_attachment = fake_parse
        warnings: list[str] = []
        try:
            start = time.perf_counter()
            attachments = await _collect_attachments(links, warnings, concurrency=3)
            elapsed = time.perf_counter() - start
        finally:
            main_module._download_attachment = original_download
            main_module._parse_attachment = original_parse

        self.assertLess(elapsed, 0.3)
        self.assertEqual([item["filename"] for item in attachments], ["1.xlsx", "3.xlsx"])
        self.assertEqual(len(warnings), 1)
        self.assertIn("闄勪欢璇诲彇澶辫触", warnings[0])


class EvidencePackV2Tests(unittest.IsolatedAsyncioTestCase):
    async def test_analyze_v2_returns_evidence_pack_for_html_page(self) -> None:
        async def fake_fetch(_: str) -> dict[str, str]:
            return {
                "html": """
                <html><head><title>Notice Title</title></head>
                <body><article><p>Published: 2026-06-10</p><p>Procurement rule text.</p></article></body></html>
                """,
                "final_url": "https://example.com/notice",
            }

        async def no_site_detail(_: str, __: list[str]) -> dict[str, str] | None:
            return None

        async def no_firecrawl(*_: object) -> str:
            return ""

        original_fetch = main_module._fetch_page
        original_site_detail = main_module._try_known_site_detail
        original_firecrawl = main_module._try_firecrawl
        try:
            main_module._fetch_page = fake_fetch
            main_module._try_known_site_detail = no_site_detail
            main_module._try_firecrawl = no_firecrawl
            response = await main_module.analyze_v2(
                main_module.AnalyzeV2Request(url="https://example.com/notice", max_attachments=0)
            )
        finally:
            main_module._fetch_page = original_fetch
            main_module._try_known_site_detail = original_site_detail
            main_module._try_firecrawl = original_firecrawl

        self.assertTrue(response.success, response.message)
        self.assertEqual(response.fetch_status["main_page"], "success")
        self.assertEqual(response.evidence_pack["source_url"], "https://example.com/notice")
        self.assertIn("Procurement rule text", response.llm_input_text)
        self.assertTrue(response.evidence_id)
        self.assertEqual(response.evidence_id, response.content_hash)

    async def test_analyze_v2_fetch_failure_returns_json_without_exception(self) -> None:
        async def failing_fetch(_: str) -> dict[str, str]:
            request = httpx.Request("GET", "https://example.com/blocked")
            response = httpx.Response(403, request=request)
            raise httpx.HTTPStatusError("Forbidden", request=request, response=response)

        async def no_site_detail(_: str, __: list[str]) -> dict[str, str] | None:
            return None

        async def no_firecrawl(*_: object) -> str:
            return ""

        original_fetch = main_module._fetch_page
        original_site_detail = main_module._try_known_site_detail
        original_firecrawl = main_module._try_firecrawl
        original_load_cached_page = main_module._load_cached_page
        try:
            main_module._fetch_page = failing_fetch
            main_module._try_known_site_detail = no_site_detail
            main_module._try_firecrawl = no_firecrawl
            main_module._load_cached_page = lambda *_: None
            response = await main_module.analyze_v2(
                main_module.AnalyzeV2Request(url="https://example.com/blocked", max_attachments=0)
            )
        finally:
            main_module._fetch_page = original_fetch
            main_module._try_known_site_detail = original_site_detail
            main_module._try_firecrawl = original_firecrawl
            main_module._load_cached_page = original_load_cached_page

        self.assertFalse(response.success)
        self.assertEqual(response.error_type, "fetch_forbidden")
        self.assertEqual(response.fetch_status["main_page"], "failed")
        self.assertEqual(response.llm_input_text, "")
        self.assertIn("鏃犳硶鎶撳彇", response.message)

    async def test_analyze_v2_large_csv_uses_table_summary_not_full_rows(self) -> None:
        async def fake_fetch(_: str) -> dict[str, str]:
            return {
                "html": '<html><body><h1>Large CSV Notice</h1><a href="/large.csv">闄勪欢锛氫骇鍝佹竻鍗?/a></body></html>',
                "final_url": "https://example.com/notice",
            }

        async def no_site_detail(_: str, __: list[str]) -> dict[str, str] | None:
            return None

        async def no_firecrawl(*_: object) -> str:
            return ""

        async def fake_download(url: str) -> DownloadedFile:
            rows = ["product,company,price,category"]
            rows.extend(f"product-{i},company-{i % 17},{i % 100 + 0.5},cat-{i % 5}" for i in range(30050))
            return DownloadedFile(
                url=url,
                filename="large.csv",
                content_type="text/csv",
                content=("\n".join(rows)).encode("utf-8"),
            )

        original_fetch = main_module._fetch_page
        original_site_detail = main_module._try_known_site_detail
        original_firecrawl = main_module._try_firecrawl
        original_download = main_module._download_attachment
        try:
            main_module._fetch_page = fake_fetch
            main_module._try_known_site_detail = no_site_detail
            main_module._try_firecrawl = no_firecrawl
            main_module._download_attachment = fake_download
            response = await main_module.analyze_v2(
                main_module.AnalyzeV2Request(
                    url="https://example.com/notice",
                    max_attachments=1,
                    max_combined_chars=20_000,
                )
            )
        finally:
            main_module._fetch_page = original_fetch
            main_module._try_known_site_detail = original_site_detail
            main_module._try_firecrawl = original_firecrawl
            main_module._download_attachment = original_download

        self.assertTrue(response.success, response.message)
        table_summary = response.evidence_pack["tables_summary"][0]
        self.assertEqual(table_summary["row_count"], 30051)
        self.assertLessEqual(len(table_summary["important_rows"]), 50)
        self.assertIn("澶ц〃宸茬粨鏋勫寲鎽樿", "\n".join(table_summary["warnings"]))
        self.assertLessEqual(len(response.llm_input_text), 20_000)
        self.assertNotIn("product-30049", response.llm_input_text)


class ReportV2GateTests(unittest.TestCase):
    def test_render_v2_parses_report_ir_tag_and_returns_warnings(self) -> None:
        raw = """
        Before text.
        <report_ir>{"title":"Test Medical Notice","suggested_filename":"test","notice_type":"notice","publish_date":"2026-06-10","source_agency":"agency","document_name":"doc","lead_paragraphs":["lead paragraph with enough text"],"sections":[{"heading":"Rules","paragraphs":["rule paragraph with enough text"],"tables":[]}],"enterprise_tips":[],"disclaimer":""}</report_ir>
        After text.
        """

        response = main_module.render_report_v2(RenderReportRequest(markdown=raw, strict_quality=True))

        self.assertTrue(response.success, response.error)
        self.assertIn("# Test Medical Notice", response.report_markdown)
        self.assertEqual(response.quality_warnings, [])

    def test_qa_parse_response_exposes_status_and_needs_fix(self) -> None:
        response = main_module.parse_report_qa(
            main_module.ReportQAParseRequest(
                qa_output='{"status":"needs_fix","issues":[{"severity":"major","category":"fact","report_text":"x"}],"unsupported_claims":[],"history_leakage":[],"missing_rules":[],"language_issues":[],"fix_instructions":["fix x"],"summary":"major issue"}'
            )
        )

        self.assertEqual(response.status, "needs_fix")
        self.assertFalse(response.blocked)
        self.assertTrue(response.needs_fix)
        self.assertEqual(len(response.issues), 1)

    def test_qa_parse_blocker_sets_block(self) -> None:
        response = main_module.parse_report_qa(
            main_module.ReportQAParseRequest(
                qa_output='{"status":"pass","issues":[{"severity":"blocker","category":"fabrication","report_text":"x"}],"unsupported_claims":[],"history_leakage":[],"missing_rules":[],"language_issues":[],"fix_instructions":[],"summary":"blocker"}'
            )
        )

        self.assertEqual(response.status, "block")
        self.assertTrue(response.blocked)

    def test_qa_parse_clean_output_passes(self) -> None:
        response = main_module.parse_report_qa(
            main_module.ReportQAParseRequest(
                qa_output='{"status":"pass","issues":[],"unsupported_claims":[],"history_leakage":[],"missing_rules":[],"language_issues":[],"fix_instructions":[],"summary":"ok"}'
            )
        )

        self.assertEqual(response.status, "pass")
        self.assertFalse(response.blocked)
        self.assertFalse(response.needs_fix)

    def test_export_checked_blocks_when_strict_and_qa_status_not_pass(self) -> None:
        response = export_report_checked(
            CheckedExportReportRequest(
                report_ir=sample_report_ir(),
                qa_status="needs_fix",
                qa_result={"summary": "needs manual confirmation"},
                strict_quality=True,
            )
        )

        self.assertFalse(response.success)
        self.assertTrue(response.blocked)
        self.assertEqual(response.download_url, "")
        self.assertIn("needs manual confirmation", response.qa_summary)

    def test_export_checked_exports_when_qa_status_pass(self) -> None:
        response = export_report_checked(
            CheckedExportReportRequest(
                report_ir=sample_report_ir(),
                qa_status="pass",
                qa_result={"summary": "ok"},
                strict_quality=True,
            )
        )

        self.assertTrue(response.success)
        self.assertFalse(response.blocked)
        self.assertIn("/download/", response.download_url)


class WorkflowYamlV2Tests(unittest.TestCase):
    def test_download_workflow_yaml_is_parseable(self) -> None:
        workflow_path = Path(__file__).resolve().parents[1] / "医药公告采购分析报告.yml"

        data = yaml.safe_load(workflow_path.read_text(encoding="utf-8"))

        self.assertEqual(data["app"]["mode"], "workflow")
        self.assertTrue(data["workflow"]["graph"]["nodes"])


if __name__ == "__main__":
    unittest.main()
