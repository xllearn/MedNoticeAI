DOCX_NS = {"w": "http://schemas.openxmlformats.org/wordprocessingml/2006/main"}


def _docx_body_text(path: Path) -> str:
    with ZipFile(path) as zf:
        root = ET.fromstring(zf.read("word/document.xml"))
    texts = [node.text or "" for node in root.findall(".//w:t", DOCX_NS)]
    return "\n".join(texts)


def _docx_paragraphs(path: Path) -> list[ET.Element]:
    with ZipFile(path) as zf:
        root = ET.fromstring(zf.read("word/document.xml"))
    return root.findall(".//w:p", DOCX_NS)


def _paragraph_text(paragraph: ET.Element) -> str:
    return "".join(node.text or "" for node in paragraph.findall(".//w:t", DOCX_NS))


def _first_run_props(paragraph: ET.Element) -> ET.Element | None:
    run = paragraph.find(".//w:r", DOCX_NS)
    if run is None:
        return None
    return run.find("w:rPr", DOCX_NS)


