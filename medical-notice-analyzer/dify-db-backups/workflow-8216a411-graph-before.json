d \u5bfc\u51fa\u53c2\u6570", "type": "code", "variables": [{"value_selector": ["report_node", "text"], "variable": "report"}]}, "height": 79, "id": "build_export_payload_node", "position": {"x": 855.714285714286, "y": 369.85714285714283}, "positionAbsolute": {"x": 855.714285714286, "y": 369.85714285714283}, "selected": false, "sourcePosition": "right", "targetPosition": "left", "type": "custom", "width": 242}, {"data": {"authorization": {"config": null, "type": "no-auth"}, "body": {"data": [{"key": "", "type": "text", "value": "{{#build_export_payload_node.payload#}}"}], "type": "json"}, "desc": "\u5c06 ReportIR \u6216 Markdown \u62a5\u544a\u5bfc\u51fa\u4e3a Word \u6587\u4ef6\u5e76\u8fd4\u56de\u4e0b\u8f7d\u94fe\u63a5", "headers": "Content-Type:application/json", "method": "post", "params": "", "retry_config": {"enabled": true, "exponential_backoff": {"enabled": true, "max_interval": 10000, "multiplier": 2}, "max_retries": 1, "retry_interval": 1000}, "selected": false, "timeout": {"connect": 10, "read": 60, "write": 30}, "title": "\u5bfc\u51fa Word \u62a5\u544a", "type": "http-request", "url": "http://host.docker.internal:8099/report/export", "variables": [], "ssl_verify": true}, "height": 151, "id": "export_report_node", "position": {"x": 1107.142857142857, "y": 211.28571428571428}, "positionAbsolute": {"x": 1107.142857142857, "y": 211.28571428571428}, "selected": false, "sourcePosition": "right", "targetPosition": "left", "type": "custom", "width": 242}, {"data": {"code": "\ndef remove_thinking(text: str) -> str:\n    import re\n    text = str(text or \"\")\n    for pattern in [\n        r\"<think\\b[^>]*>[\\s\\S]*?</think>\",\n        \"<\\\\u601d\\\\u8003\\\\b[^>]*>[\\\\s\\\\S]*?</\\\\u601d\\\\u8003>\",\n        r\"```(?:thinking|think|\\u601d\\u8003)[\\s\\S]*?```\",\n    ]:\n        text = re.sub(pattern, \"\", text, flags=re.I)\n    return text\n\n\ndef clean_lines(text: str) -> str:\n    import re\n    internal_patterns = [\n        \"^\\\\s*\\\\u6211\\\\u4eec\\\\u9700\\\\u8981.*$\",\n        \"^\\\\s*\\\\u6211\\\\u51c6\\\\u5907.*$\",\n        \"^\\\\s*\\\\u5148.*\\\\u68b3\\\\u7406.*$\",\n        r\"^\\s*We need to.*$\",\n        r\"^\\s*I need to.*$\",\n        r\"^\\s*I will.*$\",\n    ]\n    for pattern in internal_patterns:\n        text = re.sub(pattern, \"\", text, flags=re.I | re.M)\n    text = re.sub(r\"\\n{3,}\", \"\\n\\n\", text)\n    return text.strip()\n\n\ndef extract_final_report(text: str) -> str:\n    import re\n    text = remove_thinking(text)\n    match = re.search(r\"<final_report\\b[^>]*>([\\s\\S]*?)</final_report>\", text, flags=re.I)\n    if match:\n        return clean_lines(match.group(1))\n    text = re.sub(r\"<report_ir\\b[^>]*>[\\s\\S]*?</report_ir>\", \"\", text, flags=re.I)\n    return clean_lines(text)\n\n\ndef main(report: str, export_body: str) -> dict:\n    import json\n    final = extract_final_report(report)\n    download_url = \"\"\n    try:\n        data = json.loads(export_body or \"{}\")\n        download_url = data.get(\"download_url\", \"\")\n    except Exception:\n        download_url = \"\"\n    if download_url:\n        final = final + \"\\n\\n---\\n\\n[\u4e0b\u8f7d\u5206\u6790\u62a5\u544a Word \u6587\u4ef6](\" + download_url + \")\"\n    return {\"final_report\": final, \"download_url\": download_url}\n", "code_language": "python3", "desc": "\u63d0\u53d6\u6700\u7ec8\u62a5\u544a\u6b63\u6587\u5e76\u8ffd\u52a0 Word \u4e0b\u8f7d\u94fe\u63a5", "outputs": {"final_report": {"children": null, "type": "string"}, "download_url": {"children": null, "type": "string"}}, "selected": false, "title": "\u63d0\u53d6\u6b63\u6587\u5e76\u62fc\u63a5\u4e0b\u8f7d\u94fe\u63a5", "type": "code", "variables": [{"value_selector": ["report_node", "text"], "variable": "report"}, {"value_selector": ["export_report_node", "body"], "variable": "export_body"}]}, "height": 95, "id": "final_report_node", "position": {"x": 1348.5714285714287, "y": 404.1428571428571}, "positionAbsolute": {"x": 1348.5714285714287, "