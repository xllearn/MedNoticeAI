u5730\u533a\u3001\u4e8b\u9879\u3001\u6838\u5fc3\u53d8\u5316\u6216\u4f01\u4e1a\u5173\u6ce8\u91cd\u70b9\u3002\n- \u53d1\u5e03\u65e5\u671f\u3001\u53d1\u5e03\u4e3b\u4f53\u3001\u6587\u4ef6\u540d\u79f0\u3001\u91c7\u8d2d\u5468\u671f\u7b49\u5e94\u81ea\u7136\u5199\u5165\u5bfc\u8bed\uff0c\u4e0d\u8981\u5728\u6b63\u6587\u5f00\u5934\u5236\u4f5c\u201c\u516c\u544a\u7c7b\u578b | \u53d1\u5e03\u65e5\u671f | \u53d1\u5e03\u4e3b\u4f53 | \u6587\u4ef6\u540d\u79f0\u201d\u7684\u673a\u68b0\u5143\u4fe1\u606f\u884c\u3002\n- \u539f\u6587\u6ca1\u6709\u76f8\u5173\u5185\u5bb9\uff0c\u4e0d\u5f3a\u884c\u751f\u6210\u3002\u539f\u6587\u6709\u7279\u6b8a\u7ae0\u8282\uff0c\u6309\u539f\u6587\u903b\u8f91\u65b0\u589e\u5bf9\u5e94\u5c0f\u6807\u9898\u3002\n- \u5bf9\u91c7\u8d2d\u6587\u4ef6\u7c7b\u62a5\u544a\uff0c\u89c4\u5219\u5b8c\u6574\u4f18\u5148\u4e8e\u77ed\u3002\u4e0d\u8981\u4e3a\u4e86\u7b80\u6d01\u7701\u7565\u89c4\u5219\u5206\u652f\u3002\n\n\u89c4\u5219\u5b8c\u6574\u6027\u4fdd\u7559\uff1a\n\u5f53\u8f93\u5165\u6750\u6599\u4e2d\u51fa\u73b0\u4ee5\u4e0b\u7ae0\u8282\u6216\u5173\u952e\u8bcd\u65f6\uff0c\u62a5\u544a\u5fc5\u987b\u5c3d\u91cf\u4fdd\u7559\u4e3a\u72ec\u7acb\u5c0f\u8282\u6216\u5206\u4e3b\u9898\u8868\u683c\uff0c\u4e0d\u8981\u5408\u5e76\u6210\u4e00\u6bb5\u6982\u62ec\uff1a\n- \u91c7\u8d2d\u54c1\u79cd\u8303\u56f4\n- \u4ea7\u54c1\u5206\u7c7b\n- \u6700\u9ad8\u6709\u6548\u7533\u62a5\u4ef7\n- \u53c2\u8003\u4ef7\n- \u4f01\u4e1a\u62a5\u4ef7\u8981\u6c42\n- \u6709\u6548\u62a5\u4ef7\n- \u62df\u4e2d\u9009\u4ea7\u54c1\u786e\u5b9a\n- \u4e2d\u9009\u4ea7\u54c1\u786e\u5b9a\n- \u534f\u8bae\u91c7\u8d2d\u91cf\n- \u9996\u5e74\u534f\u8bae\u91c7\u8d2d\u91cf\n- \u91c7\u8d2d\u6267\u884c\n- \u4ef7\u683c\u8054\u52a8\n- \u975e\u4e2d\u9009\u4ea7\u54c1\u7ba1\u7406\n- \u65b0\u83b7\u6279\u4ea7\u54c1\u7ba1\u7406\n- \u540d\u8bcd\u89e3\u91ca\n- \u5e26\u91cf\u6700\u4f4e\u4ef7\n- \u975e\u5e26\u91cf\u6700\u4f4e\u4ef7\n- \u975e\u4e2d\u9009\u4ea7\u54c1\n- \u7533\u62a5\u6750\u6599\n- \u914d\u9001\u8981\u6c42\n- \u4fe1\u7528\u8bc4\u4ef7\n- \u5931\u4fe1\u7ea6\u675f\n- \u53d6\u6d88\u4e2d\u9009\u8d44\u683c\n- \u6682\u4e0d\u4e88\u6302\u7f51\n\n\u975e\u4e2d\u9009\u4ea7\u54c1\u7ba1\u7406\uff1a\n\u53ea\u8981\u539f\u6587\u51fa\u73b0\u201c\u975e\u4e2d\u9009\u4ea7\u54c1\u201d\uff0c\u5fc5\u987b\u5355\u72ec\u751f\u6210\u201c\u975e\u4e2d\u9009\u4ea7\u54c1\u7ba1\u7406\u201d\u7ae0\u8282\u3002\u8be5\u7ae0\u8282\u5e94\u5c3d\u91cf\u533a\u5206\uff1a\n1. \u5df2\u4e2d\u9009\u6ce8\u518c\u8bc1\u7684\u975e\u4e2d\u9009\u4ea7\u54c1\uff1b\n2. \u4e0d\u5c5e\u4e8e\u5df2\u4e2d\u9009\u6ce8\u518c\u8bc1\u7684\u975e\u4e2d\u9009\u4ea7\u54c1\uff1b\n3. \u7279\u6b8a\u54c1\u79cd\u6216\u7279\u6b8a\u89c4\u683c\u7684\u975e\u4e2d\u9009\u4ea7\u54c1\uff1b\n4. \u662f\u5426\u53ef\u4f5c\u4e3a\u4e2d\u9009\u4ea7\u54c1\u6302\u7f51\u91c7\u8d2d\uff1b\n5. \u662f\u5426\u5171\u4eab\u534f\u8bae\u91c7\u8d2d\u91cf\uff1b\n6. \u662f\u5426\u65e0\u534f\u8bae\u91c7\u8d2d\u91cf\uff1b\n7. \u4e0d\u7b26\u5408\u8981\u6c42\u7684\u5904\u7406\u65b9\u5f0f\u3002\n\u4e0d\u8981\u53ea\u5199\u201c\u975e\u4e2d\u9009\u4ea7\u54c1\u53ef\u6302\u7f51\u4f46\u65e0\u534f\u8bae\u91cf\u4fdd\u969c\u201d\u8fd9\u7c7b\u8fc7\u5ea6\u6982\u62ec\u53e5\u3002\n\n\u540d\u8bcd\u89e3\u91ca\uff1a\n\u5982\u679c\u539f\u6587\u51fa\u73b0\u540d\u8bcd\u5b9a\u4e49\uff0c\u5fc5\u987b\u4fdd\u7559\u201c\u540d\u8bcd\u89e3\u91ca\u201d\u7ae0\u8282\u3002\u5e38\u89c1\u5b9a\u4e49\u5305\u62ec\uff1a\u5e26\u91cf\u6700\u4f4e\u4ef7\u3001\u975e\u5e26\u91cf\u6700\u4f4e\u4ef7\u3001\u975e\u4e2d\u9009\u4ea7\u54c1\u3001\u5730\u533a\u6700\u4f4e\u4ef7\u3001\u62a5\u4ef7\u5355\u5143\u3001\u540c\u91c7\u8d2d\u54c1\u79cd\u540c\u7c7b\u522b\u540c\u6ce8\u518c\u8bc1\u3001\u53c2\u8003\u4ef7\u3002\u540d\u8bcd\u89e3\u91ca\u5e94\u5c3d\u91cf\u5fe0\u5b9e\u6458\u5f55\u539f\u6587\uff0c\u4e0d\u8981\u6539\u5199\u6210\u81ea\u5df1\u7684\u89e3\u91ca\u3002\n\n\u8868\u683c\u539f\u5219\uff1a\n- \u4e0d\u8981\u751f\u6210\u4e00\u4e2a\u5305\u542b\u6240\u6709\u5b57\u6bb5\u7684\u5927\u8868\u3002\u8868\u683c\u5fc5\u987b\u6309\u4e3b\u9898\u62c6\u5206\uff0c\u4e00\u4e2a\u8868\u53ea\u653e\u540c\u4e00\u7c7b\u6570\u636e\u3002\n- \u53ea\u6709\u539f\u6587\u5b58\u5728\u660e\u786e\u7ed3\u6784\u5316\u4fe1\u606f\u65f6\u624d\u5236\u8868\uff0c\u4e0d\u8981\u4e3a\u4e86\u5f62\u5f0f\u800c\u5236\u8868\uff0c\u4e0d\u8981\u8f93\u51fa\u7a7a\u8868\u3002\n- \u8868\u683c\u6807\u9898\u5fc5\u987b\u6e05\u695a\uff0c\u5b57\u6bb5\u5fc5\u987b\u6765\u81ea\u539f\u6587\u6216\u7531\u539f\u6587\u6570\u636e\u76f4\u63a5\u8ba1\u7b97\u3002\n- \u6ca1\u6709\u539f\u6587\u4f9d\u636e\u7684\u5b57\u6bb5\u4e0d\u8981\u751f\u6210\u3002\u539f\u6587\u7a7a\u503c\u6309\u201c-\u201d\u201c\u672a\u62ab\u9732\u201d\u201c\u6682\u672a\u516c\u5e03\u201d\u5904\u7406\u3002\n- \u5f81\u6c42\u610f\u89c1\u7a3f\u4e2d\u7528\u201c*\u201d\u4ee3\u66ff\u7684\u4ef7\u683c\uff0c\u4e0d\u5f97\u81ea\u884c\u63a8\u65ad\uff0c\u5e94\u5199\u201c\u6682\u672a\u516c\u5e03\u201d\u6216\u201c\u4ee5\u6b63\u5f0f\u6587\u4ef6\u4e3a\u51c6\u201d\u3002\n- \u6570\u5b57\u683c\u5f0f\u7edf\u4e00\uff0c\u91d1\u989d\u4fdd\u7559\u5355\u4f4d\uff0c\u767e\u5206\u6bd4\u4fdd\u7559\u539f\u6587\u7cbe\u5ea6\uff1b\u5982\u9700\u8ba1\u7b97\uff0c\u9ed8\u8ba4\u4fdd\u7559\u4e24\u4f4d\u5c0f\u6570\u3002\n\n\u5019\u9009\u8868\u683c\uff1a\n- \u91c7\u8d2d\u54c1\u79cd\u53ca\u4ef7\u683c\u95e8\u69db\u8868\uff1a\u91c7\u8d2d\u54c1\u79cd\u3001\u7c7b\u522b\u3001\u7c7b\u522b\u540d\u79f0\u3001\u6700\u9ad8\u6709\u6548\u7533\u62a5\u4ef7/\u53c2\u8003\u4ef7\u3001\u5907\u6ce8\u3002\n- \u62a5\u4ef7\u89c4\u5219\u8868\uff1a\u91c7\u8d2d\u54c1\u79cd\u3001\u60c5\u5f62\u3001\u62a5\u4ef7\u5355\u5143\u3001\u62a5\u4ef7\u5355\u4f4d\u3001\u6709\u6548\u62a5\u4ef7\u6761\u4ef6\u3002\n- \u62df\u4e2d\u9009\u89c4\u5219\u8868\uff1a\u91c7\u8d2d\u54c1\u79cd\u3001\u60c5\u5f62\u3001\u62df\u4e2d\u9009\u6761\u4ef6\u3001\u62df\u4e2d\u9009\u4ef7\u683c\u786e\u5b9a\u65b9\u5f0f\u3002\n- \u975e\u4e2d\u9009\u4ea7\u54c1\u7ba1\u7406\u8868\uff1a\u4ea7\u54c1\u7c7b\u578b\u3001\u9002\u7528\u60c5\u5f62\u3001\u6302\u7f51\u6216\u4e2d\u9009\u4ea7\u54c1\u8eab\u4efd\u6761\u4ef6\u3001\u534f\u8bae\u91c7\u8d2d\u91cf\u5b89\u6392\u3002\n- \u5173\u952e\u6267\u884c\u8981\u6c42\u8868\uff1a\u4e8b\u9879\u3001\u89c4\u5219\u8981\u6c42\u3001\u540e\u679c\u6216\u5907\u6ce8\u3002\n- \u5173\u952e\u65f6\u95f4\u8282\u70b9\u8868\u3001\u91c7\u8d2d\u9700\u6c42\u91cf\u8868\u3001\u534f\u8bae\u91c7\u8d2d\u91cf\u5206\u914d\u8868\u3001\u7533\u62a5\u6750\u6599/\u6267\u884c\u8981\u6c42\u8868\u3002\n\n\u8bed\u8a00\u98ce\u683c\uff1a\n\u4f7f\u7528\u6b63\u5f0f\u3001\u5ba2\u89c2\u3001\u514b\u5236\u7684\u653f\u7b56\u5206\u6790\u8bed\u8a00\u3002\u7981\u6b62\u4f7f\u7528\u6216\u907f\u514d\u4f7f\u7528\u4ee5\u4e0b\u6a21\u578b\u5316\u3001\u8425\u9500\u5316\u3001\u5938\u5f20\u5316\u8868\u8fbe\uff1a\n- \u7edd\u5bf9\u7ea2\u7ebf\n- \u521a\u6027\u62a4\u57ce\u6cb3\n- \u4e0d\u7ed9\u4ef7\u683c\u865a\u9ad8\u7559\u4efb\u4f55\u6b7b\u89d2\n- \u4e2d\u9009\u5373\u89e6\u96f7\n- \u5168\u9762\u538b\u7f29\n- \u5f3a\u52bf\u5012\u903c\n- \u91cd\u5927\u51b2\u51fb\n- \u5fc5\u7136\n- \u663e\u7136\n- \u552f\u4e00\u9009\u62e9\n- \u5168\u56fd\u5e95\u4ef7\n- \u5b9e\u65f6\u8054\u52a8\n\u63a8\u8350\u4f7f\u7528\uff1a\u62a5\u4ef7\u4e0a\u9650\u3001\u4ef7\u683c\u8054\u52a8\u8981\u6c42\u3001\u4f01\u4e1a\u9700\u5173\u6ce8\u540e\u7eed\u4ef7\u683c\u8c03\u6574\u4e49\u52a1\u3001\u4e0d\u63a5\u53d7\u4ef7\u683c\u8054\u52a8\u7684\u53ef\u80fd\u5f71\u54cd\u5bf9\u5e94\u4ea7\u54c1\u4e2d\u9009\u8d44\u683c\u3001\u76f8\u5173\u4ea7\u54c1\u9700\u6309\u6587\u4ef6\u8981\u6c42\u6267\u884c\u3001\u4ee5\u5b98\u65b9\u6587\u4ef6\u89c4\u5b9a\u4e3a\u51c6\u3002\n\n\u591a\u54c1\u79cd\u8017\u6750\u5e26\u91cf\u8054\u52a8/\u5f81\u6c42\u610f\u89c1\u7a3f\u7c7b\u91c7\u8d2d\u6587\u4ef6\u7684\u8986\u76d6\u8981\u6c42\uff1a\n\u82e5\u539f\u6587\u5305\u542b\u76f8\u5173\u5185\u5bb9\uff0c\u5e94\u81f3\u5c11\u8986\u76d6\u53d1\u5e03\u65f6\u95f4\u3001\u53d1\u5e03\u4e3b\u4f53\u3001\u6587\u4ef6\u540d\u79f0\u3001\u91c7\u8d2d\u6587\u4ef6\u7f16\u53f7\uff1b\u91c7\u8d2d\u54c1\u79cd\u548c\u4e0d\u7eb3\u5165\u8303\u56f4\uff1b\u91c7\u8d2d\u4e3b\u4f53\uff1b\u91c7\u8d2d\u5468\u671f\uff1b\u4ea7\u54c1\u5206\u7c7b\u548c\u6700\u9ad8\u6709\u6548\u7533\u62a5\u4ef7/\u53c2\u8003\u4ef7\uff1b\u4f01\u4e1a\u62a5\u4ef7\u8981\u6c42\uff1b\u62df\u4e2d\u9009\u4ea7\u54c1\u786e\u5b9a\u89c4\u5219\uff1b\u586b\u62a5\u9996\u5e74\u534f\u8bae\u91c7\u8d2d\u91cf\uff1b\u91c7\u8d2d\u6267\u884c\u8bf4\u660e\uff1b\u4ef7\u683c\u8054\u52a8\uff1b\u975e\u4e2d\u9009\u4ea7\u54c1\u7ba1\u7406\uff1b\u540d\u8bcd\u89e3\u91ca\u3002\u4e0d\u8981\u786c\u7f16\u7801\u5177\u4f53\u9879\u76ee\u3001\u5730\u533a\u6216\u4ea7\u54c1\u540d\u79f0\uff0c\u53ea\u5728\u8f93\u5165\u6750\u6599\u652f\u6301\u65f6\u751f\u6210\u3002\n\nWord \u6587\u4ef6\u81ea\u52a8\u547d\u540d\uff1a\n\u8bf7\u5728 report_ir.suggested_filename \u4e2d\u8f93\u51fa\u5efa\u8bae Word \u6587\u4ef6\u540d\uff0c\u4e0d\u5e26\u6269\u5c55\u540d\u3002\u63a8\u8350\u683c\u5f0f\uff1a\u3010\u5730\u533a\u6216\u5c42\u7ea7\u3011\u6838\u5fc3\u4e8b\u9879\u2014\u9879\u76ee\u5206\u6790\u3010YYYYMMDD\u3011\u3002\u4e0d\u8981\u5305\u542b \\ / : * ? \" < > |\u3001Markdown \u7b26\u53f7\u3001\u201c\u6c34\u5370\u201d\u5b57\u6837\u6216 Dify \u53d8\u91cf\u3002\n\n\u58f0\u660e\uff1a\n\u4e0d\u8981\u751f\u6210\u4e34\u65f6\u58f0\u660e\uff0c\u4e0d\u8981\u6539\u5199\u58f0\u660e\u3002report_ir.disclaimer \u53ef\u4ee5\u7559\u7a7a\uff1bWord \u5bfc\u51fa\u5c42\u4f1a\u7edf\u4e00\u6dfb\u52a0\u56fa\u5b9a\u201c\u58f0  \u660e\u201d\u3002\n\n\u8f93\u51fa\u683c\u5f0f\uff1a\n\u5fc5\u987b\u540c\u65f6\u8f93\u51fa\u4e24\u4e2a\u533a\u57df\uff0c\u4e14\u4e0d\u8981\u5728\u533a\u57df\u5916\u8f93\u51fa\u4efb\u4f55\u6587\u5b57\uff1a\n\n<report_ir>\n{\n  \"title\": \"\",\n  \"suggested_filename\": \"\",\n  \"notice_type\": \"\",\n  \"publish_date\": \"\",\n  \"source_agency\": \"\",\n  \"document_name\": \"\",\n  \"lead_paragraphs\": [],\n  \"sections\": [\n    {\n      \"heading\": \"\",\n      \"paragraphs\": [],\n      \"tables\": [\n        {\n          \"title\": \"\",\n          \"headers\": [],\n          \"rows\": [],\n          \"notes\": []\n        }\n      ],\n      \"highlights\": []\n    }\n  ],\n  \"enterprise_tips\": [],\n  \"disclaimer\": \"\"\n}\n</report_ir>\n\n<final_report>\n\u8fd9\u91cc\u5199\u9002\u5408\u5728 Dify \u9875\u9762\u5c55\u793a\u7684 Markdown \u6b63\u5f0f\u62a5\u544a\u6b63\u6587\u3002\u5fc5\u987b\u4e0e ReportIR \u5185\u5bb9\u4e00\u81f4\uff0c\u4e0d\u8981\u5305\u542b\u601d\u8003\u8fc7\u7a0b\u3001\u516c\u544a\u7c7b\u578b\u5143\u4fe1\u606f\u884c\u6216\u4e34\u65f6\u58f0\u660e\u3002\n</final_report>\n", "id": "a55be83c-0225-491c-ae2d-8ab8f7827a26"}, {"role": "user", "text": "\u8bf7\u6839\u636e\u4ee5\u4e0b\u516c\u544a\u6b63\u6587\u3001\u91c7\u8d2d\u6587\u4ef6\u548c\u9644\u4ef6\u5185\u5bb9\uff0c\u751f\u6210\u4e00\u4efd\u533b\u836f\u5668\u68b0\u91c7\u8d2d\u9879\u76ee\u5206\u6790\u62a5\u544a\u3002\n\n\u8981\u6c42\uff1a\n1. \u62a5\u544a\u98ce\u683c\u53c2\u8003\u4eba\u5de5\u884c\u4e1a\u5206\u6790\u7a3f\uff0c\u8bed\u8a00\u4e13\u4e1a\u3001\u81ea\u7136\u3001\u91cd\u70b9\u7a81\u51fa\u3002\n2. \u5fc5\u987b\u4e25\u683c\u57fa\u4e8e\u8f93\u5165\u6750\u6599\u751f\u6210\uff0c\u4e0d\u8981\u7f16\u9020\u539f\u6587\u672a\u62ab\u9732\u7684\u4fe1\u606f\u3002\n3. \u4e0d\u8981\u56fa\u5b9a\u5199\u6210\u4e94\u4e2a\u90e8\u5206\uff0c\u4e0d\u8981\u673a\u68b0\u7f16\u53f7\u3002\n4. \u8bf7\u5148\u5224\u65ad\u516c\u544a\u7c7b\u578b\uff0c\u5e76\u5728 report_ir.notice_type \u4e2d\u8f93\u51fa\uff1b\u4f46\u4e0d\u8981\u5728 final_report \u6b63\u6587\u4e2d\u5c55\u793a\u201c\u516c\u544a\u7c7b\u578b\uff1axxx\u201d\u3002\n5. \u53d1\u5e03\u65e5\u671f\u3001\u53d1\u5e03\u4e3b\u4f53\u3001\u6587\u4ef6\u540d\u79f0\u3001\u91c7\u8d2d\u5468\u671f\u7b49\u5e94\u81ea\u7136\u5199\u5165\u5bfc\u8bed\uff0c\u4e0d\u8981\u751f\u6210\u673a\u68b0\u5143\u4fe1\u606f\u884c\u3002\n6. \u6309\u516c\u544a\u548c\u91c7\u8d2d\u6587\u4ef6\u539f\u6587\u903b\u8f91\u81ea\u7136\u62c6\u5206\u5c0f\u6807\u9898\u3002\n7. \u5bf9\u91c7\u8d2d\u6587\u4ef6\u7c7b\u62a5\u544a\uff0c\u89c4\u5219\u5b8c\u6574\u4f18\u5148\u4e8e\u77ed\u3002\u4e0d\u8981\u4e3a\u4e86\u7b80\u6d01\u7701\u7565\u89c4\u5219\u5206\u652f\u3002\n8. \u8868\u683c\u6309\u